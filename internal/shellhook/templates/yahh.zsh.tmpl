# yahh shell integration (zsh) — generated by `yahh init zsh`; do not edit.
typeset -g _yahh_bin={{.BinPath}}
typeset -g _yahh_snap={{.SnapPath}}
[[ -n "$YAHH_DATA_DIR" ]] && _yahh_snap="$YAHH_DATA_DIR/snapshot"
typeset -g _yahh_root=""
typeset -g _yahh_m_root="" _yahh_m_hist=""
typeset -gi _yahh_pushed=0
typeset -gi _yahh_nosave=0

# Resolve $PWD against the snapshot the yahh binary maintains — pure shell,
# nothing forked, so the cd hot path stays in the microsecond range.
# Sets _yahh_m_root/_yahh_m_hist on a match. Returns: 0 match, 1 no realm,
# 2 yahh disabled, 3 snapshot unavailable (caller falls back to the binary).
_yahh_lookup() {
  _yahh_m_root="" _yahh_m_hist=""
  [[ -r "$_yahh_snap" ]] || return 3
  local -a lines
  lines=("${(@f)$(<$_yahh_snap)}")   # $(<file) is fork-free in zsh
  case "${lines[1]}" in
    "yahh1 enabled=0") return 2 ;;
    "yahh1 enabled=1") ;;
    *) return 3 ;;
  esac
  local line root rest pwdp="${PWD:A}"
  for line in "${lines[@]:1}"; do
    root="${line%%$'\t'*}"
    [[ "$root" == "$line" ]] && continue
    if [[ "$PWD" == "$root" || "$PWD" == "$root"/* || "$pwdp" == "$root" || "$pwdp" == "$root"/* ]]; then
      rest="${line#*$'\t'}"
      _yahh_m_root="$root"
      _yahh_m_hist="${rest%%$'\t'*}"
      return 0
    fi
  done
  return 1
}

# Switch to a realm history file. `fc -p` saves the global history context
# on zsh's history stack; the stack is kept at depth <= 1 by popping any
# previously pushed realm first.
_yahh_enter() {
  local histfile="$1"
  [[ "$histfile" == "$HISTFILE" ]] && return 0
  if [[ -n "$HISTFILE" ]] && (( SAVEHIST > 0 && ! _yahh_nosave )); then
    fc -AI 2>/dev/null   # append this session's new events; never truncates
  fi
  if (( _yahh_pushed )); then
    # fc -P saves the popped history like a shell exit would; blank
    # HISTFILE first when this save is unwanted (the pop restores it).
    (( _yahh_nosave )) && HISTFILE=""
    fc -P
    _yahh_pushed=0
  fi
  fc -p "$histfile"
  _yahh_pushed=1
  [[ -s "$histfile" ]] && fc -R "$histfile"
  return 0
}

# Restore the global history context.
_yahh_exit() {
  (( _yahh_pushed )) || return 0
  if [[ -n "$HISTFILE" ]] && (( SAVEHIST > 0 && ! _yahh_nosave )); then
    fc -AI 2>/dev/null
  fi
  # fc -P saves the popped history like a shell exit would; blank
  # HISTFILE first when this save is unwanted (the pop restores it).
  (( _yahh_nosave )) && HISTFILE=""
  fc -P
  _yahh_pushed=0
  return 0
}

_yahh_chpwd() {
  if [[ -n "$YAHH_DISABLE" ]]; then
    if [[ -n "$_yahh_root" ]]; then
      _yahh_root=""
      _yahh_exit
    fi
    return 0
  fi
  # Fast path: still inside the cached realm root — nothing to do.
  if [[ -n "$_yahh_root" && ( "$PWD" == "$_yahh_root" || "$PWD" == "$_yahh_root"/* ) ]]; then
    return 0
  fi
  local rc
  _yahh_lookup
  rc=$?
  if (( rc == 3 )); then
    # Snapshot unavailable — ask the binary (which also regenerates it).
    local out
    out="$("$_yahh_bin" resolve --shell zsh --pwd "$PWD" 2>/dev/null)" || out=""
    if [[ -n "$out" ]]; then
      _yahh_m_root="${out%%$'\t'*}"
      _yahh_m_hist="${out#*$'\t'}"
      rc=0
    fi
  fi
  if (( rc == 0 )) && [[ -n "$_yahh_m_hist" ]]; then
    _yahh_root="$_yahh_m_root"
    _yahh_enter "$_yahh_m_hist"
    # Bookkeeping off the hot path: last-used timestamp + histfile creation.
    { "$_yahh_bin" resolve --shell zsh --pwd "$PWD" >/dev/null 2>&1 } &!
  else
    _yahh_root=""
    _yahh_exit
  fi
  return 0
}

# Wrapper so realm changes made by yahh commands apply without a `cd`.
yahh() {
  "$_yahh_bin" "$@"
  local ret=$?
  case "$1" in
    remove|clean)
      # The realm's history file may just have been archived — a final
      # append would silently recreate it, so skip the save this once.
      _yahh_root=""
      _yahh_nosave=1
      _yahh_chpwd
      _yahh_nosave=0
      ;;
    create|mv|rename|enable|disable)
      _yahh_root=""
      _yahh_chpwd
      ;;
  esac
  return $ret
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd _yahh_chpwd

# Resolve the starting directory once, at the first prompt — after zsh has
# finished reading the startup history file.
_yahh_startup() {
  add-zsh-hook -d precmd _yahh_startup
  unfunction _yahh_startup
  _yahh_chpwd
}
add-zsh-hook precmd _yahh_startup
{{- if .AutoClean}}

# Throttled orphan cleanup; the binary exits immediately unless a week has
# passed since the last run.
{ "$_yahh_bin" clean --auto >/dev/null 2>&1 } &!
{{- end}}
{{- if .Completions}}

if (( $+functions[compdef] )); then
  source <("$_yahh_bin" completion zsh 2>/dev/null)
fi
{{- end}}
