# yahh shell integration (zsh) — generated by `yahh init zsh`; do not edit.
typeset -g _yahh_bin={{.BinPath}}
typeset -g _yahh_root=""
typeset -gi _yahh_pushed=0
typeset -gi _yahh_nosave=0

# Switch to a realm history file. `fc -p` saves the global history context
# on zsh's history stack; the stack is kept at depth <= 1 by popping any
# previously pushed realm first.
_yahh_enter() {
  local histfile="$1"
  [[ "$histfile" == "$HISTFILE" ]] && return 0
  if [[ -n "$HISTFILE" ]] && (( SAVEHIST > 0 && ! _yahh_nosave )); then
    fc -AI 2>/dev/null   # append this session's new events; never truncates
  fi
  if (( _yahh_pushed )); then
    # fc -P saves the popped history like a shell exit would; blank
    # HISTFILE first when this save is unwanted (the pop restores it).
    (( _yahh_nosave )) && HISTFILE=""
    fc -P
    _yahh_pushed=0
  fi
  fc -p "$histfile"
  _yahh_pushed=1
  [[ -s "$histfile" ]] && fc -R "$histfile"
  return 0
}

# Restore the global history context.
_yahh_exit() {
  (( _yahh_pushed )) || return 0
  if [[ -n "$HISTFILE" ]] && (( SAVEHIST > 0 && ! _yahh_nosave )); then
    fc -AI 2>/dev/null
  fi
  # fc -P saves the popped history like a shell exit would; blank
  # HISTFILE first when this save is unwanted (the pop restores it).
  (( _yahh_nosave )) && HISTFILE=""
  fc -P
  _yahh_pushed=0
  return 0
}

_yahh_chpwd() {
  if [[ -n "$YAHH_DISABLE" ]]; then
    if [[ -n "$_yahh_root" ]]; then
      _yahh_root=""
      _yahh_exit
    fi
    return 0
  fi
  # Fast path: still inside the cached realm root — no binary call needed.
  if [[ -n "$_yahh_root" && ( "$PWD" == "$_yahh_root" || "$PWD" == "$_yahh_root"/* ) ]]; then
    return 0
  fi
  local out
  out="$("$_yahh_bin" resolve --shell zsh --pwd "$PWD" 2>/dev/null)" || out=""
  if [[ -n "$out" ]]; then
    _yahh_root="${out%%$'\t'*}"
    _yahh_enter "${out#*$'\t'}"
  else
    _yahh_root=""
    _yahh_exit
  fi
  return 0
}

# Wrapper so realm changes made by yahh commands apply without a `cd`.
yahh() {
  "$_yahh_bin" "$@"
  local ret=$?
  case "$1" in
    remove|clean)
      # The realm's history file may just have been archived — a final
      # append would silently recreate it, so skip the save this once.
      _yahh_root=""
      _yahh_nosave=1
      _yahh_chpwd
      _yahh_nosave=0
      ;;
    create|mv|rename|enable|disable)
      _yahh_root=""
      _yahh_chpwd
      ;;
  esac
  return $ret
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd _yahh_chpwd

# Resolve the starting directory once, at the first prompt — after zsh has
# finished reading the startup history file.
_yahh_startup() {
  add-zsh-hook -d precmd _yahh_startup
  unfunction _yahh_startup
  _yahh_chpwd
}
add-zsh-hook precmd _yahh_startup
{{- if .AutoClean}}

# Throttled orphan cleanup; the binary exits immediately unless a week has
# passed since the last run.
{ "$_yahh_bin" clean --auto >/dev/null 2>&1 } &!
{{- end}}
{{- if .Completions}}

if (( $+functions[compdef] )); then
  source <("$_yahh_bin" completion zsh 2>/dev/null)
fi
{{- end}}
