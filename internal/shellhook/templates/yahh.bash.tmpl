# yahh shell integration (bash) — generated by `yahh init bash`; do not edit.
_yahh_bin={{.BinPath}}
_yahh_default_hist="${HISTFILE:-$HOME/.bash_history}"
_yahh_root=""
_yahh_last_pwd=""
_yahh_nosave=0
# bash 3.2 (stock macOS) does not reliably track new lines for `history -a`;
# fall back to writing the whole in-memory list there (best effort).
if ((BASH_VERSINFO[0] >= 4)); then _yahh_hist_w=0; else _yahh_hist_w=1; fi

# Switch the active history file. The save must run BEFORE HISTFILE is
# reassigned so this session's new lines land in the file they belong to.
_yahh_swap() {
  local histfile="$1"
  [[ "$histfile" == "$HISTFILE" ]] && return 0
  if (( ! _yahh_nosave )); then
    if (( _yahh_hist_w )); then history -w; else history -a; fi
  fi
  HISTFILE="$histfile"
  history -c
  [[ -s "$histfile" ]] && history -r
  return 0
}

_yahh_hook() {
  [[ "$PWD" == "$_yahh_last_pwd" ]] && return 0
  _yahh_last_pwd="$PWD"
  if [[ -n "$YAHH_DISABLE" ]]; then
    if [[ -n "$_yahh_root" ]]; then
      _yahh_root=""
      _yahh_swap "$_yahh_default_hist"
    fi
    return 0
  fi
  # Fast path: still inside the cached realm root — no binary call needed.
  if [[ -n "$_yahh_root" ]]; then
    case "$PWD" in
      "$_yahh_root" | "$_yahh_root"/*) return 0 ;;
    esac
  fi
  local out
  out="$("$_yahh_bin" resolve --shell bash --pwd "$PWD" 2>/dev/null)" || out=""
  if [[ -n "$out" ]]; then
    _yahh_root="${out%%$'\t'*}"
    _yahh_swap "${out#*$'\t'}"
  else
    _yahh_root=""
    _yahh_swap "$_yahh_default_hist"
  fi
  return 0
}

# Wrapper so realm changes made by yahh commands apply without a `cd`.
yahh() {
  "$_yahh_bin" "$@"
  local ret=$?
  case "$1" in
    remove|clean)
      # The realm's history file may just have been archived — a final
      # append would silently recreate it, so skip the save this once.
      _yahh_root=""
      _yahh_last_pwd=""
      _yahh_nosave=1
      _yahh_hook
      _yahh_nosave=0
      ;;
    create|mv|rename|enable|disable)
      _yahh_root=""
      _yahh_last_pwd=""
      _yahh_hook
      ;;
  esac
  return $ret
}

# Register the hook without clobbering an existing PROMPT_COMMAND.
if [[ "$(declare -p PROMPT_COMMAND 2>/dev/null)" == "declare -a"* ]]; then
  PROMPT_COMMAND+=(_yahh_hook)
elif ((BASH_VERSINFO[0] > 5 || (BASH_VERSINFO[0] == 5 && BASH_VERSINFO[1] >= 1))); then
  PROMPT_COMMAND=(${PROMPT_COMMAND:+"$PROMPT_COMMAND"} _yahh_hook)
else
  PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND; }_yahh_hook"
fi
{{- if .AutoClean}}

# Throttled orphan cleanup; the binary exits immediately unless a week has
# passed since the last run.
( "$_yahh_bin" clean --auto >/dev/null 2>&1 & )
{{- end}}
{{- if .Completions}}

if [[ -n "${BASH_COMPLETION_VERSINFO-}" ]]; then
  source <("$_yahh_bin" completion bash 2>/dev/null)
fi
{{- end}}
