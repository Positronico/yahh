# yahh shell integration (bash) — generated by `yahh init bash`; do not edit.
_yahh_bin={{.BinPath}}
_yahh_snap={{.SnapPath}}
[ -n "$YAHH_DATA_DIR" ] && _yahh_snap="$YAHH_DATA_DIR/snapshot"
_yahh_default_hist="${HISTFILE:-$HOME/.bash_history}"
_yahh_root=""
_yahh_m_root="" _yahh_m_hist=""
_yahh_last_pwd=""
_yahh_nosave=0

# Resolve $PWD against the snapshot the yahh binary maintains — pure shell
# on the hot path (one $(pwd -P) fork only when a symlinked cwd must be
# re-checked). Sets _yahh_m_root/_yahh_m_hist on a match. Returns: 0 match,
# 1 no realm, 2 yahh disabled, 3 snapshot unavailable (fall back to binary).
_yahh_lookup() {
  _yahh_m_root="" _yahh_m_hist=""
  [[ -r "$_yahh_snap" ]] || return 3
  local header
  IFS= read -r header < "$_yahh_snap" || return 3
  case "$header" in
    "yahh1 enabled=0") return 2 ;;
    "yahh1 enabled=1") ;;
    *) return 3 ;;
  esac
  local root zh bh have_realms=0 pwdp
  while IFS=$'\t' read -r root zh bh; do
    case "$root" in "yahh1 "* | "") continue ;; esac
    have_realms=1
    case "$PWD" in
      "$root" | "$root"/*)
        _yahh_m_root="$root" _yahh_m_hist="$bh"
        return 0
        ;;
    esac
  done < "$_yahh_snap"
  (( have_realms )) || return 1
  pwdp=$(pwd -P)
  [[ "$pwdp" == "$PWD" ]] && return 1
  while IFS=$'\t' read -r root zh bh; do
    case "$root" in "yahh1 "* | "") continue ;; esac
    case "$pwdp" in
      "$root" | "$root"/*)
        _yahh_m_root="$root" _yahh_m_hist="$bh"
        return 0
        ;;
    esac
  done < "$_yahh_snap"
  return 1
}
# bash 3.2 (stock macOS) does not reliably track new lines for `history -a`;
# fall back to writing the whole in-memory list there (best effort).
if ((BASH_VERSINFO[0] >= 4)); then _yahh_hist_w=0; else _yahh_hist_w=1; fi

# Switch the active history file. The save must run BEFORE HISTFILE is
# reassigned so this session's new lines land in the file they belong to.
_yahh_swap() {
  local histfile="$1"
  [[ "$histfile" == "$HISTFILE" ]] && return 0
  if (( ! _yahh_nosave )); then
    if (( _yahh_hist_w )); then history -w; else history -a; fi
  fi
  HISTFILE="$histfile"
  history -c
  [[ -s "$histfile" ]] && history -r
  return 0
}

_yahh_hook() {
  [[ "$PWD" == "$_yahh_last_pwd" ]] && return 0
  _yahh_last_pwd="$PWD"
  if [[ -n "$YAHH_DISABLE" ]]; then
    if [[ -n "$_yahh_root" ]]; then
      _yahh_root=""
      _yahh_swap "$_yahh_default_hist"
    fi
    return 0
  fi
  # Fast path: still inside the cached realm root — nothing to do.
  if [[ -n "$_yahh_root" ]]; then
    case "$PWD" in
      "$_yahh_root" | "$_yahh_root"/*) return 0 ;;
    esac
  fi
  local rc
  _yahh_lookup
  rc=$?
  if (( rc == 3 )); then
    # Snapshot unavailable — ask the binary (which also regenerates it).
    local out
    out="$("$_yahh_bin" resolve --shell bash --pwd "$PWD" 2>/dev/null)" || out=""
    if [[ -n "$out" ]]; then
      _yahh_m_root="${out%%$'\t'*}"
      _yahh_m_hist="${out#*$'\t'}"
      rc=0
    fi
  fi
  if (( rc == 0 )) && [[ -n "$_yahh_m_hist" ]]; then
    _yahh_root="$_yahh_m_root"
    _yahh_swap "$_yahh_m_hist"
    # Bookkeeping off the hot path: last-used timestamp + histfile creation.
    ( "$_yahh_bin" resolve --shell bash --pwd "$PWD" >/dev/null 2>&1 & )
  else
    _yahh_root=""
    _yahh_swap "$_yahh_default_hist"
  fi
  return 0
}

# Wrapper so realm changes made by yahh commands apply without a `cd`.
yahh() {
  "$_yahh_bin" "$@"
  local ret=$?
  case "$1" in
    remove|clean)
      # The realm's history file may just have been archived — a final
      # append would silently recreate it, so skip the save this once.
      _yahh_root=""
      _yahh_last_pwd=""
      _yahh_nosave=1
      _yahh_hook
      _yahh_nosave=0
      ;;
    create|mv|rename|enable|disable)
      _yahh_root=""
      _yahh_last_pwd=""
      _yahh_hook
      ;;
  esac
  return $ret
}

# Register the hook without clobbering an existing PROMPT_COMMAND.
if [[ "$(declare -p PROMPT_COMMAND 2>/dev/null)" == "declare -a"* ]]; then
  PROMPT_COMMAND+=(_yahh_hook)
elif ((BASH_VERSINFO[0] > 5 || (BASH_VERSINFO[0] == 5 && BASH_VERSINFO[1] >= 1))); then
  PROMPT_COMMAND=(${PROMPT_COMMAND:+"$PROMPT_COMMAND"} _yahh_hook)
else
  PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND; }_yahh_hook"
fi
{{- if .AutoClean}}

# Throttled orphan cleanup; the binary exits immediately unless a week has
# passed since the last run.
( "$_yahh_bin" clean --auto >/dev/null 2>&1 & )
{{- end}}
{{- if .Completions}}

if [[ -n "${BASH_COMPLETION_VERSINFO-}" ]]; then
  source <("$_yahh_bin" completion bash 2>/dev/null)
fi
{{- end}}
